# Copy this file to .env and fill in your values

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
OWNER_ID=your_telegram_user_id

# Channel
REQUIRED_CHANNEL=@your_channel
REQUIRED_CHANNEL_LINK=https://t.me/your_channel

# API Endpoints (optional - only if different from config defaults)
# DEEPSEEK_API_URL=https://api.example.com/api/ai/deepseek
# GROK_API_URL=https://api.example.com/api/ai/grok
